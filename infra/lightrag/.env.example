COMPOSE_PROJECT_NAME=liquidation

# Локальные paths являются только defaults. Переопределять в ignored infra/lightrag/.env.
LIGHTRAG_DATA_PATH=./data
LIGHTRAG_BACKUP_PATH=./backups
LIGHTRAG_REPORT_PATH=docs/reports/rag
LIGHTRAG_INDEXED_PATHS=docs/
LIGHTRAG_API_PORT=19621
LIGHTRAG_HOST=127.0.0.1

LIQUIDATION_OMNIROUTE_PORT=21128
LIQUIDATION_FREE_DEEPSEEK_PORT=19655
LIQUIDATION_OMNIROUTE_BASE_URL=http://liquidation-omniroute:20128
LIQUIDATION_FREE_DEEPSEEK_BASE_URL=http://liquidation-free-deepseek:9655
LIQUIDATION_EMBEDDINGS_BASE_URL=http://127.0.0.1:11434

OMNIROUTE_IMAGE=diegosouzapw/omniroute:latest
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
FREE_DEEPSEEK_LOCAL_IMAGE=liquidation-free-deepseek:local
FREE_DEEPSEEK_REPO=https://github.com/ForgetMeAI/FreeDeepseekAPI.git
FREE_DEEPSEEK_REF=e54d324e1d6be1f4d074f5c7f078ae5d94deade8
FREE_DEEPSEEK_AUTH_FILE=./data/secrets/deepseek-auth.json
FREE_DEEPSEEK_INFISICAL_SECRET_NAME=FREE_DEEPSEEK_AUTH_JSON
FREE_DEEPSEEK_INFISICAL_ENV=dev
FREE_DEEPSEEK_INFISICAL_PATH=/

KIRO_PROVIDER_NAME=kiro
KIRO_COMBO_NAME=my-ai
LIGHTRAG_LLM_MODEL=my-ai
LIGHTRAG_OPENAI_API_KEY=liquidation-local-omniroute
LIGHTRAG_EMBEDDING_BINDING=ollama
LIGHTRAG_EMBEDDING_BINDING_HOST=http://host.docker.internal:11434
LIGHTRAG_EMBEDDING_MODEL=nomic-embed-text
LIGHTRAG_EMBEDDING_DIM=768
LIGHTRAG_CHUNK_TOKEN_SIZE=900
LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=100
LIGHTRAG_INGEST_TIMEOUT_SECONDS=7200

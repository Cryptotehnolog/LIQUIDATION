COMPOSE_PROJECT_NAME=liquidation

# Все host ports держим на loopback, чтобы не раскрывать локальную dev memory наружу.
APERAG_HOST=127.0.0.1
APERAG_WEB_PORT=23000
APERAG_API_PORT=28000
LIQUIDATION_FREE_DEEPSEEK_PORT=19655
LIQUIDATION_EMBEDDING_PORT=28001

# Runtime paths. В repository хранится только example; настоящий .env ignored.
APERAG_DATA_PATH=./data
APERAG_REPORT_PATH=docs/reports/aperag
APERAG_INDEXED_PATHS=docs/

# ApeRAG images. Перед deployment обязательно запускать scripts/check-images.ps1.
APERAG_BASE_IMAGE=docker.io/apecloud/aperag:v0.0.0-nightly
APERAG_IMAGE=liquidation-aperag:local
APERAG_FRONTEND_IMAGE=docker.io/apecloud/aperag-frontend:v0.0.0-nightly
APERAG_POSTGRES_IMAGE=docker.io/apecloud/pgvector:pg16
APERAG_REDIS_IMAGE=docker.io/apecloud/redis:6
APERAG_QDRANT_IMAGE=docker.io/apecloud/qdrant:v1.13.4
APERAG_ELASTICSEARCH_IMAGE=docker.io/apecloud/elasticsearch:8.8.2

# ApeRAG app config.
POSTGRES_DB=aperag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=password
JWT_SECRET=liquidation-local-dev-change-me
AUTH_TYPE=cookie
REGISTER_MODE=unlimited
VECTOR_DB_TYPE=qdrant
GRAPH_DB_TYPE=postgresql
OBJECT_STORE_TYPE=local
CHUNK_SIZE=400
CHUNK_OVERLAP_SIZE=20

# Наши LLM routes.
LIQUIDATION_FREE_DEEPSEEK_BASE_URL=http://liquidation-free-deepseek:9655
APERAG_PRIMARY_MODEL=deepseek-chat
APERAG_FALLBACK_MODEL=deepseek-chat
APERAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

EMBEDDING_IMAGE=liquidation-embedding:local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_CACHE_DIR=/models

FREE_DEEPSEEK_LOCAL_IMAGE=liquidation-free-deepseek:local
FREE_DEEPSEEK_REPO=https://github.com/ForgetMeAI/FreeDeepseekAPI.git
FREE_DEEPSEEK_REF=e54d324e1d6be1f4d074f5c7f078ae5d94deade8
FREE_DEEPSEEK_AUTH_FILE=./data/secrets/deepseek-auth.json
FREE_DEEPSEEK_INFISICAL_SECRET_NAME=FREE_DEEPSEEK_AUTH_JSON
FREE_DEEPSEEK_INFISICAL_ENV=dev
FREE_DEEPSEEK_INFISICAL_PATH=/
